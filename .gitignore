# .gitignore - Git 버전 관리에서 제외할 파일들

# ================================================================================
# 분석 결과 및 데이터
# ================================================================================

# 출력 디렉토리
3rd_analysis_results/
results/
output/

# 로그 파일
*.log
logs/
.snakemake/logs/

# 임시 파일
tmp/
temp/
*.tmp

# ================================================================================
# Snakemake 관련
# ================================================================================

# Snakemake 메타데이터
.snakemake/

# Benchmark 결과
benchmarks/

# DAG 그래프
dag.pdf
rulegraph.pdf
*.dot

# ================================================================================
# 설정 파일 (개인 정보 포함 가능)
# ================================================================================

# 실제 설정 파일 (예제는 유지)
config/config.yaml
!config/config.example.yaml
!config/cluster_config.yaml

# 입력 파일 목록 (prepare_inputs.py 결과)
filelist.csv
*.csv

# 클러스터 설정 백업
cluster.yaml
profile/

# ================================================================================
# Python 관련
# ================================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# ================================================================================
# R 관련
# ================================================================================

# R history and session data
.Rhistory
.RData
.Rapp.history

# R temporary files
*.Rout
*.Rcheck/

# ================================================================================
# 데이터 파일
# ================================================================================

# 큰 데이터 파일
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.bam
*.bam.bai
*.cram
*.cram.crai
*.bed
*.bed.gz
*.bw
*.bigWig

# FASTA 파일
*.fa
*.fasta
*.fa.gz
*.fasta.gz
*.fai

# ================================================================================
# OS 관련
# ================================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ================================================================================
# IDE 관련
# ================================================================================

# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# ================================================================================
# 컨테이너 관련
# ================================================================================

# Singularity
*.sif
*.simg
singularity-images/

# Docker
docker-compose.override.yml

# ================================================================================
# 기타
# ================================================================================

# 압축 파일
*.zip
*.tar
*.tar.gz
*.tgz
*.rar

# 백업 파일
*.bak
*.backup
*~

# 테스트 데이터
test_data/
!test_data/.gitkeep
